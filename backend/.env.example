# Copiar a backend/.env y completar valores reales

NODE_ENV=development
PORT=3001

# Obligatorio en producción (Render): cadena aleatoria larga
JWT_SECRET=change-me-to-a-long-random-secret

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mantec_erc
DB_USER=postgres
DB_PASSWORD=postgres

# Origen del frontend (CORS). En Render: https://tu-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

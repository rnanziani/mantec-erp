# Copiar a backend/.env y completar valores reales

NODE_ENV=development
PORT=3001

# Obligatorio en producción (Render): cadena aleatoria larga
JWT_SECRET=change-me-to-a-long-random-secret

# PostgreSQL (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bd_etiquetas
DB_USER=postgres
DB_PASSWORD=postgres

# Render: vincula la BD al Web Service y usa DATABASE_URL, o copia Internal Database URL:
# DATABASE_URL=postgresql://user:pass@dpg-xxx.oregon-postgres.render.com/bd_etiquetas
# DB_SSL=true  (opcional; SSL se activa solo fuera de localhost)

# Origen del frontend (CORS). En Render Static Site: https://mantec-erp-1.onrender.com
# Sin barra final. Opcional: CORS_ORIGINS=https://otro-dominio.com,https://otro2.com
FRONTEND_URL=http://localhost:5173

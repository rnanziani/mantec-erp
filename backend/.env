PORT=3001
NODE_ENV=development

# ================================================
# Database Configuration (PostgreSQL)
# ================================================
# IMPORTANTE: Actualiza estos valores según tu instalación de PostgreSQL
# Por defecto, PostgreSQL usa el usuario 'postgres' con la contraseña que configuraste durante la instalación

DB_HOST=localhost
DB_PORT=5432
DB_NAME=bd_etiquetas

# Usuario de PostgreSQL (propietario de la tabla)
DB_USER=postgres

# CAMBIA ESTO: Ingresa tu contraseña de PostgreSQL aquí
# Esta es la contraseña que configuraste al instalar PostgreSQL
DB_PASSWORD=662606876*themis
# ================================================
# Notas:
# - Si no recuerdas tu contraseña, puedes restablecerla desde pgAdmin
# - Asegúrate de que PostgreSQL esté corriendo (Servicios de Windows)
# - La base de datos 'mantec_erp' debe existir (ver database/README.md)
# ================================================
